# KOVITAD.shop server configuration — copy to .env and fill in. Never commit .env.

# Public base URL of the site (used to build Stripe redirect + download links).
APP_URL=http://localhost:8080

# Where the SQLite database lives. In Docker this defaults to /data/kovitad.db.
# DB_PATH=/data/kovitad.db

# Stripe (Thailand account, THB). Get keys from the Stripe dashboard.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Recurring Price id for the all-access membership (created in Stripe).
STRIPE_MEMBERSHIP_PRICE_ID=price_xxx

# Transactional email (Resend). Without a key, receipts are logged to the console.
RESEND_API_KEY=
EMAIL_FROM=KOVITAD.shop <hello@kovitad.shop>
