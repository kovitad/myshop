# KOVITAD.shop configuration — copy to .env on the server and fill in.
# NEVER commit .env. On Lightsail the container reads this via --env-file.

# Public base URL (used to build Stripe redirect + download links). Production:
APP_URL=https://kovitad.shop

# SQLite DB path (defaults to /data/kovitad.db in Docker — leave unless you know why).
# DB_PATH=/data/kovitad.db

# The user with this email becomes the site admin (/admin CMS).
ADMIN_EMAIL=kovitad@gmail.com

# ── Stripe (Thailand account, THB) ──────────────────────────────────────
# Payment Links are created in the Stripe dashboard (one per product, pasted
# into /admin). The app only needs these two secrets, for the webhook + the
# server-side payment verification. Never expose them in the browser.
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Only needed if you sell the recurring membership (a Stripe Price id).
STRIPE_MEMBERSHIP_PRICE_ID=

# ── Transactional email (Resend) ────────────────────────────────────────
# Without a key, receipts/tickets are logged to the container console instead.
RESEND_API_KEY=
EMAIL_FROM=KOVITAD.shop <hello@kovitad.shop>
SUPPORT_INBOX=kovitad@gmail.com

# ── Contact details shown on the site (also editable in /admin → Profile) ─
SUPPORT_EMAIL=kovitad@gmail.com
SUPPORT_PHONE=0839799546
SUPPORT_LINE_ID=kovitadj
