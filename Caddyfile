# Local / IP access. Useful before DNS is pointed at the Lightsail instance.
:80 {
  root * /srv
  encode gzip zstd

  route {
    respond /healthz "ok" 200
    try_files {path} {path}/ /index.html
    file_server
  }
}

# Production domain. Caddy automatically provisions and renews HTTPS certificates.
kovitad.shop, www.kovitad.shop {
  root * /srv
  encode gzip zstd

  header {
    X-Content-Type-Options nosniff
    Referrer-Policy strict-origin-when-cross-origin
  }

  @static path *.css *.js *.jsx *.json *.png *.jpg *.jpeg *.gif *.webp *.bmp *.svg *.ico *.woff *.woff2
  header @static Cache-Control "public, max-age=604800"

  route {
    respond /healthz "ok" 200
    try_files {path} {path}/ /index.html
    file_server
  }
}
